{
  "protocol": "curve_gauges",
  "version": "1.0",
  "standard_abis": {
    "gauge_deposit": {
      "name": "deposit",
      "type": "function",
      "inputs": [{"name": "_value", "type": "uint256"}],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    "gauge_withdraw": {
      "name": "withdraw",
      "type": "function",
      "inputs": [{"name": "_value", "type": "uint256"}],
      "outputs": [],
      "stateMutability": "nonpayable"
    }
  },
  "actions": {
    "curve_gauge_deposit": {
      "description": "Deposit LP tokens into a Curve gauge for CRV rewards",
      "target_contract": "$gauge_address",
      "function_name": "deposit",
      "function_selector": "0xb6b55f25",
      "abi_source": "standard",
      "standard_abi_key": "gauge_deposit",
      "value_logic": {"type": "zero"},
      "approvals": [{"token": "$__lp_token_address", "spender": "$gauge_address"}],
      "required_payload_args": ["gauge_address", "__lp_token_address", "_value", "human_readable_amount"],
      "payload_args": {
        "gauge_address": {"source": "resolve_ens_or_hex", "llm_field": "gauge_address"},
        "__lp_token_address": {"source": "resolve_ens_or_hex", "llm_field": "lp_token_address"},
        "_value": {
          "source": "resolve_amount_or_balance",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": 18,
          "balance_of": "$__lp_token_address"
        },
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} LP tokens"}
      },
      "param_mapping": [{"name": "_value", "source": "arg", "arg_key": "_value", "coerce": "uint256"}]
    },
    "curve_gauge_withdraw": {
      "description": "Withdraw LP tokens from a Curve gauge",
      "target_contract": "$gauge_address",
      "function_name": "withdraw",
      "function_selector": "0x2e1a7d4d",
      "abi_source": "standard",
      "standard_abi_key": "gauge_withdraw",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["gauge_address", "_value", "human_readable_amount"],
      "payload_args": {
        "gauge_address": {"source": "resolve_ens_or_hex", "llm_field": "gauge_address"},
        "_value": {
          "source": "resolve_amount_or_balance",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": 18,
          "balance_of": "$gauge_address"
        },
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} LP tokens"}
      },
      "param_mapping": [{"name": "_value", "source": "arg", "arg_key": "_value", "coerce": "uint256"}]
    },
    "curve_mint_crv": {
      "description": "Mint (claim) CRV rewards from a Curve gauge",
      "target_contract": "minter",
      "function_name": "mint",
      "function_selector": "0x6a627842",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["gauge_addr", "human_readable_amount"],
      "payload_args": {
        "gauge_addr": {"source": "resolve_ens_or_hex", "llm_field": "gauge_address"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "CRV rewards"}
      },
      "param_mapping": [{"name": "gauge_addr", "source": "arg", "arg_key": "gauge_addr", "coerce": "address"}]
    }
  }
}
