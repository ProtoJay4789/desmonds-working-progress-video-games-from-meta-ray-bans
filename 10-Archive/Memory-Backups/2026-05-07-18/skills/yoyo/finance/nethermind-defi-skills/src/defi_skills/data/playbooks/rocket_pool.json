{
  "protocol": "rocket_pool",
  "version": "1.0",
  "actions": {
    "rocketpool_stake": {
      "description": "Stake ETH via Rocket Pool (receive rETH)",
      "target_contract": "deposit_pool",
      "function_name": "deposit",
      "function_selector": "0xd0e30db0",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "from_arg", "source_arg": "value"},
      "required_payload_args": ["value", "human_readable_amount"],
      "payload_args": {
        "value": {
          "source": "resolve_amount_or_balance",
          "llm_field": "amount",
          "fallback_llm_fields": ["value"],
          "decimals_from": "$native",
          "balance_of": "$native"
        },
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} ETH"}
      },
      "param_mapping": []
    },
    "rocketpool_unstake": {
      "description": "Burn rETH to unstake from Rocket Pool (receive ETH)",
      "target_contract": "reth",
      "function_name": "burn",
      "function_selector": "0x42966c68",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["_rethAmount", "human_readable_amount"],
      "payload_args": {
        "_rethAmount": {
          "source": "resolve_amount_or_balance",
          "llm_field": "amount",
          "fallback_llm_fields": ["_rethAmount", "amount"],
          "decimals_from": 18,
          "balance_of": "$reth"
        },
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} rETH"}
      },
      "param_mapping": [{"name": "_rethAmount", "source": "arg", "arg_key": "_rethAmount", "coerce": "uint256"}]
    }
  }
}
