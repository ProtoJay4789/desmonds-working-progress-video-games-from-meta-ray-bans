{
  "protocol": "aave_v3",
  "version": "1.0",
  "actions": {
    "aave_supply": {
      "description": "Supply asset to Aave V3 lending pool",
      "target_contract": "pool",
      "function_name": "supply",
      "function_selector": "0x617ba037",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "approvals": [{"token": "$asset", "spender": "target_contract"}],
      "required_payload_args": ["asset", "amount", "onBehalfOf", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "amount": {
          "source": "resolve_amount_or_balance",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": "$asset",
          "balance_of": "$asset"
        },
        "onBehalfOf": {"source": "resolve_ens_or_hex", "llm_field": "onBehalfOf", "context_field": "from_address"},
        "referralCode": {"source": "constant", "value": 0},
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} {asset}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "amount", "source": "arg", "arg_key": "amount", "coerce": "uint256"},
        {"name": "onBehalfOf", "source": "arg", "arg_key": "onBehalfOf", "coerce": "address"},
        {"name": "referralCode", "source": "constant", "value": 0, "coerce": "uint256"}
      ]
    },
    "aave_withdraw": {
      "description": "Withdraw asset from Aave V3 lending pool",
      "target_contract": "pool",
      "function_name": "withdraw",
      "function_selector": "0x69328dec",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["asset", "amount", "to", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "amount": {
          "source": "resolve_amount_or_max",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": "$asset"
        },
        "to": {"source": "resolve_ens_or_hex", "llm_field": "to", "context_field": "from_address"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} {asset}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "amount", "source": "arg", "arg_key": "amount", "coerce": "uint256"},
        {"name": "to", "source": "arg", "arg_key": "to", "coerce": "address"}
      ]
    },
    "aave_borrow": {
      "description": "Borrow asset from Aave V3 lending pool",
      "target_contract": "pool",
      "function_name": "borrow",
      "function_selector": "0xa415bcad",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["asset", "amount", "onBehalfOf", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "amount": {
          "source": "resolve_amount",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": "$asset"
        },
        "interestRateMode": {
          "source": "resolve_interest_rate_mode",
          "llm_field": "interest_rate_mode",
          "fallback_llm_fields": ["interestRateMode", "rate_mode"],
          "default": 2
        },
        "referralCode": {"source": "constant", "value": 0},
        "onBehalfOf": {"source": "resolve_ens_or_hex", "llm_field": "onBehalfOf", "context_field": "from_address"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} {asset}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "amount", "source": "arg", "arg_key": "amount", "coerce": "uint256"},
        {
          "name": "interestRateMode",
          "source": "arg",
          "arg_key": "interestRateMode",
          "coerce": "uint256"
        },
        {"name": "referralCode", "source": "constant", "value": 0, "coerce": "uint256"},
        {"name": "onBehalfOf", "source": "arg", "arg_key": "onBehalfOf", "coerce": "address"}
      ]
    },
    "aave_repay": {
      "description": "Repay borrowed asset on Aave V3",
      "target_contract": "pool",
      "function_name": "repay",
      "function_selector": "0x573ade81",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "approvals": [{"token": "$asset", "spender": "target_contract"}],
      "required_payload_args": ["asset", "amount", "onBehalfOf", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "amount": {
          "source": "resolve_amount_or_max",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": "$asset"
        },
        "interestRateMode": {
          "source": "resolve_interest_rate_mode",
          "llm_field": "interest_rate_mode",
          "fallback_llm_fields": ["interestRateMode", "rate_mode"],
          "default": 2
        },
        "onBehalfOf": {"source": "resolve_ens_or_hex", "llm_field": "onBehalfOf", "context_field": "from_address"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} {asset}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "amount", "source": "arg", "arg_key": "amount", "coerce": "uint256"},
        {
          "name": "interestRateMode",
          "source": "arg",
          "arg_key": "interestRateMode",
          "coerce": "uint256"
        },
        {"name": "onBehalfOf", "source": "arg", "arg_key": "onBehalfOf", "coerce": "address"}
      ]
    },
    "aave_set_collateral": {
      "description": "Enable or disable an asset as collateral on Aave V3",
      "target_contract": "pool",
      "function_name": "setUserUseReserveAsCollateral",
      "function_selector": "0x5a3b74b9",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["asset", "useAsCollateral", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "useAsCollateral": {"source": "llm_passthrough", "llm_field": "useAsCollateral"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "{asset} collateral={useAsCollateral}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "useAsCollateral", "source": "arg", "arg_key": "useAsCollateral", "coerce": "bool"}
      ]
    },
    "aave_repay_with_atokens": {
      "description": "Repay borrowed asset using aTokens (no approval needed)",
      "target_contract": "pool",
      "function_name": "repayWithATokens",
      "function_selector": "0x2dad97d4",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["asset", "amount", "human_readable_amount"],
      "payload_args": {
        "asset": {"source": "resolve_token_address", "llm_field": "asset"},
        "amount": {
          "source": "resolve_amount_or_max",
          "llm_field": "amount",
          "fallback_llm_fields": ["amount"],
          "decimals_from": "$asset"
        },
        "interestRateMode": {
          "source": "resolve_interest_rate_mode",
          "llm_field": "interest_rate_mode",
          "fallback_llm_fields": ["interestRateMode", "rate_mode"],
          "default": 2
        },
        "human_readable_amount": {"source": "compute_human_readable", "template": "{amount} {asset}"}
      },
      "param_mapping": [
        {"name": "asset", "source": "arg", "arg_key": "asset", "coerce": "address"},
        {"name": "amount", "source": "arg", "arg_key": "amount", "coerce": "uint256"},
        {
          "name": "interestRateMode",
          "source": "arg",
          "arg_key": "interestRateMode",
          "coerce": "uint256"
        }
      ]
    },
    "aave_claim_rewards": {
      "description": "Claim all Aave V3 rewards to self",
      "target_contract": "rewards_controller",
      "function_name": "claimAllRewardsToSelf",
      "function_selector": "0xbf90f63a",
      "abi_source": "etherscan_cache",
      "value_logic": {"type": "zero"},
      "required_payload_args": ["assets", "human_readable_amount"],
      "payload_args": {
        "assets": {"source": "resolve_aave_reward_assets", "pool_address": "$pool"},
        "human_readable_amount": {"source": "compute_human_readable", "template": "Aave rewards"}
      },
      "param_mapping": [{"name": "assets", "source": "arg", "arg_key": "assets", "coerce": "address_array"}]
    }
  }
}
