# Environment variables take precedence over ~/.defi-skills/config.json.
# Copy this file to .env and fill in the values you need.

# Wallet address (required)
WALLET_ADDRESS=

# LLM API key (only needed for `defi-skills chat`)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Ethereum RPC (needed for ENS, swaps, "max" amounts, on-chain queries)
ALCHEMY_API_KEY=

# Optional
ETHERSCAN_API_KEY=
ONEINCH_API_KEY=
THEGRAPH_API_KEY=
