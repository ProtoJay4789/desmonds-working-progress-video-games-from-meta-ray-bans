          "description": "Slippage tolerance in percent (e.g. \"1\" for 1%). Default: 0.5%"
        },
        "min_out": {
          "source": "resolve_pendle_min_out",
          "function_name": "swapExactTokenForPt",
          "slippage_bps": 50
        },
        "human_readable_amount": {
          "source": "compute_human_readable",
          "template": "Swap {amount} {asset} for PT on Pendle market"
        }
