{
  "meta": {
    "title": "GENTECH DASHBOARD",
    "subtitle": "AAE DeFi Milestone Template",
    "dataUrl": "defi-data.json",
    "refreshMs": 30000,
    "version": "v1.0",
    "brand": "GENTECH DASHBOARD",
    "badge": "AAE Template #001"
  },
  "theme": {
    "mode": "dark",
    "colors": {
      "--bg": "#0a0e17",
      "--panel-bg": "#111827",
      "--panel-border": "#1f2937",
      "--panel-shadow": "rgba(0,255,136,0.05)",
      "--text": "#e5e7eb",
      "--text-dim": "#6b7280",
      "--gold": "#00ff88",
      "--gold-dim": "#059669",
      "--accent": "#00ccff",
      "--danger": "#ff3366",
      "--success": "#00ff88",
      "--radius": "12px"
    },
    "fonts": {
      "heading": "'Inter', -apple-system, sans-serif",
      "body": "'Inter', -apple-system, sans-serif"
    },
    "container": { "maxWidth": "1100px" }
  },
  "tabs": [
    { "id": "overview", "label": "Overview", "icon": "📊", "sections": ["portfolio", "alloc", "positions"] },
    { "id": "yields", "label": "Yields", "icon": "🌾", "sections": ["yield-positions", "yield-progress"] },
    { "id": "history", "label": "Activity", "icon": "📜", "sections": ["transactions", "milestones"] }
  ],
  "sections": [
    {
      "id": "portfolio",
      "title": "Portfolio Snapshot",
      "icon": "💰",
      "type": "stats",
      "dataSource": "portfolio",
      "cardTemplate": {
        "fields": [
          { "key": "totalValue", "label": "Total Value", "format": "money" },
          { "key": "change24h", "label": "24h Change", "format": "percent" },
          { "key": "activePositions", "label": "Positions", "format": "text" },
          { "key": "activeChains", "label": "Chains", "format": "text" }
        ]
      }
    },
    {
      "id": "alloc",
      "title": "Asset Allocation",
      "icon": " pie chart",
      "type": "progress",
      "dataSource": "allocation",
      "progressConfig": {
        "items": [
          { "label": "Ethereum (ETH + stETH)", "valueKey": "eth", "color": "#627eea" },
          { "label": "Stablecoins (USDC)", "valueKey": "usdc", "color": "#2775ca" },
          { "label": "DeFi Tokens (AERO)", "valueKey": "defi", "color": "#00ff88" }
        ]
      }
    },
    {
      "id": "positions",
      "title": "Active Positions",
      "icon": "🏦",
      "type": "table",
      "dataSource": "positions",
      "cardTemplate": {
        "fields": [
          { "key": "protocol", "label": "Protocol", "format": "text" },
          { "key": "chain", "label": "Chain", "format": "badge" },
          { "key": "asset", "label": "Asset" },
          { "key": "deposited", "label": "Deposited", "format": "money" },
          { "key": "currentValue", "label": "Value", "format": "money" },
          { "key": "pnl", "label": "P&L", "format": "money" }
        ]
      }
    },
    {
      "id": "yield-positions",
      "title": "Yield Farming",
      "icon": "🌾",
      "type": "table",
      "dataSource": "yieldFarms",
      "cardTemplate": {
        "fields": [
          { "key": "protocol", "label": "Protocol" },
          { "key": "pair", "label": "Pair" },
          { "key": "tvl", "label": "Pool TVL", "format": "money" },
          { "key": "apy", "label": "APY", "format": "percent" },
          { "key": "earned", "label": "Earned", "format": "money" },
          { "key": "status", "label": "Status", "format": "badge" }
        ]
      }
    },
    {
      "id": "yield-progress",
      "title": "Yield Progress",
      "icon": "📈",
      "type": "progress",
      "dataSource": "yieldProgress",
      "progressConfig": {
        "items": [
          { "label": "Aerodrome USDC/ETH", "valueKey": "aerodrome", "color": "#00ff88" },
          { "label": "Beefy USDC Vault", "valueKey": "beefy", "color": "#00ccff" },
          { "label": "Morpho WETH Lending", "valueKey": "morpho", "color": "#c9a84c" }
        ]
      }
    },
    {
      "id": "transactions",
      "title": "Recent Activity",
      "icon": "📜",
      "type": "table",
      "dataSource": "transactions",
      "cardTemplate": {
        "fields": [
          { "key": "date", "label": "Date", "format": "date" },
          { "key": "type", "label": "Type", "format": "badge" },
          { "key": "token", "label": "Token" },
          { "key": "amount", "label": "Amount" },
          { "key": "usd", "label": "USD", "format": "money" },
          { "key": "status", "label": "Status", "format": "badge" }
        ]
      }
    },
    {
      "id": "milestones",
      "title": "AAE Milestones",
      "icon": "🎯",
      "type": "checklist",
      "dataSource": "milestones",
      "checklistConfig": {
        "storageKey": "aae-defi-milestones",
        "groupBy": "category",
        "showProgress": true
      }
    }
  ],
  "footer": {
    "brand": "GENTECH DASHBOARD",
    "version": "AAE DeFi Template v1.0",
    "showTimestamp": true
  }
}
