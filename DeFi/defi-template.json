{
  "meta": {
    "title": "GENTECH DASHBOARD",
    "subtitle": "AAE DeFi — LFJ LP Position",
    "dataUrl": "defi-data.json",
    "refreshMs": 30000,
    "version": "v1.2",
    "brand": "GENTECH DASHBOARD",
    "badge": "AAE DeFi"
  },
  "theme": {
    "mode": "dark",
    "colors": {
      "--bg": "#0a0e17",
      "--panel-bg": "#111827",
      "--panel-border": "#1f2937",
      "--panel-shadow": "rgba(0,255,136,0.05)",
      "--text": "#e5e7eb",
      "--text-dim": "#6b7280",
      "--gold": "#00ff88",
      "--gold-dim": "#059669",
      "--accent": "#00ccff",
      "--danger": "#ff3366",
      "--success": "#00ff88",
      "--radius": "12px"
    },
    "fonts": {
      "heading": "'Inter', -apple-system, sans-serif",
      "body": "'Inter', -apple-system, sans-serif"
    },
    "container": { "maxWidth": "1100px" }
  },
  "tabs": [
    { "id": "curve", "label": "LP Curve", "icon": "🔔", "sections": ["lp-curve", "lp-stats"] },
    { "id": "milestones", "label": "Milestones", "icon": "🏆", "sections": ["fee-milestones", "trajectory"] },
    { "id": "activity", "label": "Activity", "icon": "📜", "sections": ["transactions", "milestones"] }
  ],
  "sections": [
    {
      "id": "lp-curve",
      "title": "Liquidity Distribution — Curve Shape",
      "icon": "📊",
      "type": "custom",
      "dataSource": "curveData",
      "customRender": "lpCurve"
    },
    {
      "id": "lp-stats",
      "title": "Position Details",
      "icon": "💰",
      "type": "stats",
      "dataSource": "lpPosition",
      "cardTemplate": {
        "fields": [
          { "key": "pair", "label": "Pair", "format": "text" },
          { "key": "feeTier", "label": "Fee Tier", "format": "text" },
          { "key": "shape", "label": "Shape", "format": "text" },
          { "key": "currentPrice", "label": "Current Price", "format": "text" },
          { "key": "rangeMin", "label": "Range Min", "format": "text" },
          { "key": "rangeMax", "label": "Range Max", "format": "text" }
        ]
      }
    },
    {
      "id": "fee-milestones",
      "title": "Fee Income Milestones",
      "icon": "🏆",
      "type": "custom",
      "dataSource": "feeMilestones",
      "customRender": "feeMilestones"
    },
    {
      "id": "trajectory",
      "title": "Trajectory to Next Milestone",
      "icon": "📈",
      "type": "custom",
      "dataSource": "feeMilestones",
      "customRender": "trajectory"
    },
    {
      "id": "transactions",
      "title": "Recent Activity",
      "icon": "📜",
      "type": "table",
      "dataSource": "transactions",
      "cardTemplate": {
        "fields": [
          { "key": "date", "label": "Date", "format": "date" },
          { "key": "type", "label": "Type", "format": "badge" },
          { "key": "token", "label": "Token" },
          { "key": "amount", "label": "Amount" },
          { "key": "usd", "label": "USD", "format": "money" },
          { "key": "status", "label": "Status", "format": "badge" }
        ]
      }
    },
    {
      "id": "milestones",
      "title": "AAE Milestones",
      "icon": "🎯",
      "type": "checklist",
      "dataSource": "milestones",
      "checklistConfig": {
        "storageKey": "aae-defi-milestones",
        "groupBy": "category",
        "showProgress": true
      }
    }
  ],
  "footer": {
    "brand": "GENTECH DASHBOARD",
    "version": "AAE DeFi v1.2 — Milestones",
    "showTimestamp": true
  }
}
