<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="2048" height="2048" viewBox="0 0 2048 2048">
  <defs>
    <!-- Background gradient -->
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" style="stop-color:#1a1a28"/>
      <stop offset="100%" style="stop-color:#0B0B0F"/>
    </radialGradient>
    
    <!-- G gradient: silver to blue -->
    <linearGradient id="gFill" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#BDC3C7"/>
      <stop offset="40%" style="stop-color:#95A5A6"/>
      <stop offset="100%" style="stop-color:#2E86C1"/>
    </linearGradient>
    
    <!-- Red accent -->
    <linearGradient id="redAccent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#E63946"/>
      <stop offset="100%" style="stop-color:#C0392B"/>
    </linearGradient>
    
    <!-- Silver ring -->
    <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#BDC3C7"/>
      <stop offset="50%" style="stop-color:#5D6D7E"/>
      <stop offset="100%" style="stop-color:#2E86C1"/>
    </linearGradient>
    
    <filter id="glow">
      <feGaussianBlur stdDeviation="12" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="softGlow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="2048" height="2048" rx="120" fill="url(#bg)"/>
  
  <!-- Subtle tech grid -->
  <g opacity="0.03" stroke="#BDC3C7" stroke-width="1">
    <line x1="0" y1="0" x2="2048" y2="0"/><line x1="0" y1="128" x2="2048" y2="128"/><line x1="0" y1="256" x2="2048" y2="256"/><line x1="0" y1="384" x2="2048" y2="384"/><line x1="0" y1="512" x2="2048" y2="512"/><line x1="0" y1="640" x2="2048" y2="640"/><line x1="0" y1="768" x2="2048" y2="768"/><line x1="0" y1="896" x2="2048" y2="896"/><line x1="0" y1="1024" x2="2048" y2="1024"/><line x1="0" y1="1152" x2="2048" y2="1152"/><line x1="0" y1="1280" x2="2048" y2="1280"/><line x1="0" y1="1408" x2="2048" y2="1408"/><line x1="0" y1="1536" x2="2048" y2="1536"/><line x1="0" y1="1664" x2="2048" y2="1664"/><line x1="0" y1="1792" x2="2048" y2="1792"/><line x1="0" y1="1920" x2="2048" y2="1920"/>
    <line x1="0" y1="0" x2="0" y2="2048"/><line x1="128" y1="0" x2="128" y2="2048"/><line x1="256" y1="0" x2="256" y2="2048"/><line x1="384" y1="0" x2="384" y2="2048"/><line x1="512" y1="0" x2="512" y2="2048"/><line x1="640" y1="0" x2="640" y2="2048"/><line x1="768" y1="0" x2="768" y2="2048"/><line x1="896" y1="0" x2="896" y2="2048"/><line x1="1024" y1="0" x2="1024" y2="2048"/><line x1="1152" y1="0" x2="1152" y2="2048"/><line x1="1280" y1="0" x2="1280" y2="2048"/><line x1="1408" y1="0" x2="1408" y2="2048"/><line x1="1536" y1="0" x2="1536" y2="2048"/><line x1="1664" y1="0" x2="1664" y2="2048"/><line x1="1792" y1="0" x2="1792" y2="2048"/><line x1="1920" y1="0" x2="1920" y2="2048"/>
  </g>
  
  <!-- Red accent line - top -->
  <rect x="120" y="135" width="1808" height="4" rx="2" fill="url(#redAccent)" opacity="0.7"/>
  
  <!-- Outer ring -->
  <circle cx="1024" cy="1024" r="780" fill="none" stroke="url(#ringGrad)" stroke-width="4" opacity="0.4"/>
  <circle cx="1024" cy="1024" r="800" fill="none" stroke="#BDC3C7" stroke-width="1.5" opacity="0.15"/>
  
  <!-- G Logo -->
  <g filter="url(#glow)" transform="translate(1024, 984)">
    <!-- G body -->
    <path d="M 60 -520
             A 560 560 0 1 0 60 520
             L 60 280
             L 520 280
             L 520 180
             L 60 180
             A 340 340 0 0 1 60 -180
             A 340 340 0 0 1 280 -90
             L 520 -90
             L 520 -190
             L 280 -190
             A 340 340 0 0 1 60 -180
             A 560 560 0 1 0 60 520
             Z"
          fill="url(#gFill)" opacity="0.92"/>
    
    <!-- Inner circle cutout -->
    <circle cx="0" cy="0" r="220" fill="url(#bg)"/>
    
    <!-- Inner ring detail -->
    <circle cx="0" cy="0" r="225" fill="none" stroke="#BDC3C7" stroke-width="2" opacity="0.2"/>
    <circle cx="0" cy="0" r="210" fill="none" stroke="#E63946" stroke-width="1.5" opacity="0.15"/>
    
    <!-- Center dot -->
    <circle cx="0" cy="0" r="16" fill="#E63946" opacity="0.7" filter="url(#softGlow)"/>
  </g>
  
  <!-- Red accent line - bottom -->
  <rect x="120" y="1893" width="1808" height="4" rx="2" fill="url(#redAccent)" opacity="0.7"/>
  
  <!-- Text -->
  <text x="1024" y="1988" text-anchor="middle" font-family="'Helvetica Neue', 'Arial Black', sans-serif" font-size="96" font-weight="800" fill="#BDC3C7" letter-spacing="32" opacity="0.9">GENTECH</text>
  <text x="1024" y="2028" text-anchor="middle" font-family="'Helvetica Neue', 'Arial', sans-serif" font-size="40" font-weight="300" fill="#E63946" letter-spacing="20" opacity="0.6">H Q</text>
</svg>